{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "dev.gvnr/gvnr",
  "title": "Gvnr",
  "description": "AI agent substrate: spend caps, rate limits, idempotency, reconciliation, approval bridges",
  "version": "1.6.0",
  "websiteUrl": "https://gvnr.dev",
  "repository": {
    "url": "https://github.com/mightbesaad/gvnr",
    "source": "github"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://gvnr.dev/mcp",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer API key obtained from POST https://gvnr.dev/v1/account",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "license": "MIT",
      "categories": [
        "agent-infrastructure",
        "spend-management",
        "rate-limiting",
        "idempotency",
        "approval-workflows",
        "x402-payments"
      ],
      "docs": "https://gvnr.dev",
      "pricing": "https://gvnr.dev#pricing",
      "manifest": "https://gvnr.dev/.well-known/mcp.json",
      "agentSkills": "https://gvnr.dev/.well-known/agent-skills/index.json"
    }
  }
}
